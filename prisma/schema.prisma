// 1. The Generator
generator client {
  provider = "prisma-client-js"
}

// 2. The Datasource
datasource db {
  provider = "postgresql"
  
}

// 3. Your Existing Enums
enum Role {
  ADMIN
  STAFF
}

// --- NEW ENUMS FOR LAUNDRY SYSTEM ---
enum PaymentStatus {
  UNPAID
  PAID
}

enum ServiceStatus {
  ON_GOING
  COMPLETED
  CLAIMED
  CANCELLED
}

enum PaymentMethod {
  CASH
  GCASH
  CARD
}

// 4. Your User Model (Working perfectly!)
model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  password             String    
  name                 String
  location             String?
  phone                String?
  role                 Role      @default(STAFF)
  
  isTwoFactorEnabled   Boolean   @default(false)
  twoFactorSecret      String?  
  
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // This tells Prisma that a User (Staff) can process many transactions
  transactions         Transaction[]
  
  // ---> NEW: KONEKSYON PARA SA NOTIFICATION SETTINGS (Ito ang fix sa P1012 Error) <---
  notificationSettings NotificationSettings?
}

// --- NEW MODELS FOR LAUNDRY SYSTEM ---

model Service {
  id          String   @id @default(uuid())
  name        String   // e.g., "WASH", "DRY", "WASH & FOLD"
  price       Float    // Default price
  
  items       TransactionItem[]
}

model Transaction {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique // e.g., "T04", "T05"
  customerName  String        // From your Add Entry modal
  
  // Statuses
  paymentStatus PaymentStatus @default(UNPAID)
  serviceStatus ServiceStatus @default(ON_GOING)
  paymentMethod PaymentMethod? // Optional if unpaid
  
  totalAmount   Float         @default(0) // Total from the modal
  
  // Dates
  transactionDate DateTime // The Date picked in the modal
  claimDate       DateTime? // Logs when claimed
  createdAt       DateTime      @default(now()) 
  updatedAt       DateTime      @updatedAt

  // Soft Delete (Satisfies the "Prevents permanent deletion" rule)
  isDeleted     Boolean       @default(false) 

  // Audit Trail: Link back to the User model
  userId        String?  
  user          User?         @relation(fields: [userId], references: [id])

  // Items in this transaction
  items         TransactionItem[]
}

model TransactionItem {
  id            String      @id @default(uuid())
  quantity      Float       @default(1) // Can be used for Weight (e.g., 3.5 kg)
  priceAtTime   Float       // Historical price tracking
  
  // Link to Transaction
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  
  // Link to Service
  serviceId     String
  service       Service     @relation(fields: [serviceId], references: [id])
}

// ==========================================
// --- NEW MODELS FOR NOTIFICATIONS SYSTEM ---
// ==========================================

enum NotificationType {
  info
  success
  warning
  error
}

// LEGACY: Hindi ginalaw para ma-preserve ang mga lumang notifications
model Notification {
  id          String           @id @default(uuid())
  title       String
  message     String
  isRead      Boolean          @default(false)
  type        NotificationType @default(info)
  timestamp   DateTime         @default(now())
}

// NEW: Model para sa preferences/settings ng bawat user
model NotificationSettings {
  id                   String  @id 
  user                 User    @relation(fields: [id], references: [id], onDelete: Cascade)
  
  // Alert Types
  orderUpdates         Boolean @default(true)
  paymentNotifications Boolean @default(true)
  newOrders            Boolean @default(true)
  orderCompletion      Boolean @default(true)
  lowStock             Boolean @default(true)
  systemUpdates        Boolean @default(false)
  
  // Notification Channels
  emailNotifications   Boolean @default(true)
  pushNotifications    Boolean @default(true)
  smsNotifications     Boolean @default(false)
}

// ==========================================
// --- NEW MODEL FOR INVENTORY SYSTEM ---
// ==========================================

model InventoryItem {
  id           String   @id @default(uuid())
  name         String   // e.g., "DETERGENT POWDER"
  currentValue Float    @default(0) // e.g., 15
  maxValue     Float    @default(100) // Para ma-compute ang % level sa UI
  unit         String   // e.g., "kg Total", "L Total", "pcs Total"
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}